{
  "name": "kpd100",
  "version": "1.0.0",
  "engines": {
    "node": "20.10.0",
    "npm": "10.2.4"
  },
  "scripts": {
    "server": "nodemon server",
    "client-install": "npm install --prefix client",
    "client": "npm run start --prefix client",
    "dev": "concurrently \"NODE_ENV=production npm run server\" \"npm run client\"",
    "start": "node server.js",
    "heroku-postbuild": "NODE_ENV=production npm run client-install && npm run build --prefix client"
  },
  "private": true,
  "dependencies": {
    "bootstrap-icons": "^1.11.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "html-to-text": "^9.0.5",
    "morgan": "^1.10.0",
    "node": "^20.10.0",
    "nodemailer": "^6.9.5",
    "npm": "^10.2.4",
    "pug": "^3.0.2",
    "sib-api-v3-sdk": "^8.5.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}
